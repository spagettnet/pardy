# Pick ONE — direct Anthropic gets full server-tool support (web_search etc.).
# OpenRouter works too via the Anthropic-compatible /messages endpoint;
# in that mode web_search is provided via :online model suffix (Exa-backed).
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
# Optional overrides for OpenRouter routing
# OPENROUTER_BASE_URL=https://openrouter.ai/api  # (SDK appends /v1/messages)
# OPENROUTER_MODEL_PREFIX=anthropic/

JUDGE_MODEL=claude-haiku-4-5-20251001
BOARD_MODEL=claude-opus-4-7

TTS_URL=http://127.0.0.1:8000
TTS_VOICE=af_heart

STT_URL=http://127.0.0.1:8001
STT_MODEL=small.en
STT_LANGUAGE=en

PORT=3030
